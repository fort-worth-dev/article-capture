# Copy to .env and fill in. Never commit the real .env.

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...
# Haiku is the cost-smart default for high-volume summarizing.
# Bump to a Sonnet model if you want richer summaries.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Notion ---
NOTION_API_KEY=ntn_...
# The 32-char id from your database URL (see README).
NOTION_DATABASE_ID=
