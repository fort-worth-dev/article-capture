# Copy to .env and fill in. Never commit the real .env.

# --- Anthropic (article + YouTube summarization) ---
ANTHROPIC_API_KEY=sk-ant-...
# Haiku is the cost-smart default for high-volume summarizing.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Gemini (YouTube transcription only) ---
# Get a key at https://aistudio.google.com/apikey — separate from a consumer AI Pro subscription.
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# --- Notion ---
NOTION_API_KEY=ntn_...
# The 32-char id from your database URL (see README).
NOTION_DATABASE_ID=
